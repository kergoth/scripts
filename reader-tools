def resolve_token() -> str:
    if token := os.environ.get("READWISE_TOKEN"):
        log.debug("Using READWISE_TOKEN from environment")
        return token
    cli_config = Path.home() / ".readwise-cli.json"
    if cli_config.exists():
        try:
            data = json.loads(cli_config.read_text())
            # Only use CLI credentials if they're a personal access token, not OAuth.
            # OAuth tokens from `npx @readwise/cli login` don't work with the v3 API.
            if data.get("auth_type") != "oauth":
                if token := data.get("access_token") or data.get("token"):
                    log.debug("Using token from ~/.readwise-cli.json")
                    return token
        except json.JSONDecodeError:
            pass
    console.print("[red]No Readwise token found.[/]")
    console.print("  Set READWISE_TOKEN to your personal access token:")
    console.print("  https://readwise.io/access_token")
    console.print("  (The CLI's OAuth token from 'npx @readwise/cli login' is not supported)")
    sys.exit(1)


def setup_logging(verbose: int, quiet: int) -> None:
    levels = [logging.ERROR, logging.WARNING, logging.INFO, logging.DEBUG]
    index = max(0, min(len(levels) - 1, 2 + verbose - quiet))  # default: INFO
    logging.basicConfig(
        level=levels[index],
        handlers=[RichHandler(console=log_console, show_path=False, markup=True)],
        format="%(message)s",
        force=True,
    )
    # httpx and httpcore both log internal request/response events at INFO/DEBUG.
    # Suppress both — our own log.debug statements at call sites are sufficient.
    logging.getLogger("httpx").setLevel(logging.WARNING)
    logging.getLogger("httpcore").setLevel(logging.WARNING)


def add_cache_arguments(parser: argparse.ArgumentParser) -> None:
