#!/bin/sh
# Usage: git-setup [git-init-options] [directory]
#
# Initialize a git repository with an empty root commit, then create
# an initial commit from the working tree. Any options before the
# directory are forwarded to `git init`.
#
# Options:
#     -h, --help    Show this help message

set -eu

case "${1:-}" in
    -h|--help)
        sed -n '/^# Usage:/,/^# *-h[, ]/p' "$0" | sed 's/^# //;s/^#$//'
        exit 0
        ;;
esac

directory=
for arg; do
    case "$arg" in
        -*)
            continue
            ;;
        *)
            directory="$arg"
            break
            ;;
    esac
done

git init "$@"
if [ -n "$directory" ]; then
    cd "$directory"
fi
if ! git rev-parse HEAD >/dev/null 2>&1; then
    git commit --allow-empty -m "Root commit"
    git add .
    git commit --allow-empty -m "Initial commit"
fi
